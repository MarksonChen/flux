<views:GlassWindowBase x:Class="Flux.Views.HistoryWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Flux.Views"
        Title="History"
        Width="460" Height="700"
        MinWidth="380" MinHeight="250"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid>
        <!-- Gradient overlay -->
        <Border CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Content -->
        <DockPanel Margin="20">
            <Grid DockPanel.Dock="Top" Margin="0,0,0,12">
                <TextBlock Text="Event History"
                           Foreground="White" FontSize="15" FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <Button Style="{StaticResource CloseButton}" Click="OnClose"
                        HorizontalAlignment="Right" VerticalAlignment="Center"/>
            </Grid>
            <DataGrid x:Name="HistoryGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserReorderColumns="False"
                      CanUserResizeRows="False"
                      SelectionMode="Single"
                      SelectionUnit="FullRow">
                <!-- Columns created in code-behind -->
            </DataGrid>
        </DockPanel>
    </Grid>
</views:GlassWindowBase>
