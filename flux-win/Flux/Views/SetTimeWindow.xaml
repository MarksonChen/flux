<views:GlassWindowBase x:Class="Flux.Views.SetTimeWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Flux.Views"
        Title="Set Time"
        Width="320" Height="200"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid>
        <!-- Gradient overlay -->
        <Border CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Content -->
        <StackPanel Margin="24,20" VerticalAlignment="Center">
            <TextBlock Text="Set Timer" Foreground="White" FontSize="15" FontWeight="SemiBold"
                       Margin="0,0,0,16"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Column="0" Grid.Row="0" Text="HOURS" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" FontSize="10" FontWeight="Medium"/>
                <TextBlock Grid.Column="2" Grid.Row="0" Text="MINUTES" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" FontSize="10" FontWeight="Medium"/>
                <TextBlock Grid.Column="4" Grid.Row="0" Text="SECONDS" Foreground="#66FFFFFF"
                           HorizontalAlignment="Center" FontSize="10" FontWeight="Medium"/>

                <TextBox x:Name="HoursBox" Grid.Column="0" Grid.Row="2"
                         HorizontalAlignment="Stretch" TextAlignment="Center"
                         FontSize="20" MaxLength="4"
                         PreviewTextInput="OnPreviewTextInput"
                         GotFocus="OnTextBoxGotFocus"/>
                <TextBlock Grid.Column="1" Grid.Row="2" Text=":" Foreground="#55FFFFFF"
                           FontSize="20" FontWeight="Light" VerticalAlignment="Center" Margin="6,0"/>
                <TextBox x:Name="MinutesBox" Grid.Column="2" Grid.Row="2"
                         HorizontalAlignment="Stretch" TextAlignment="Center"
                         FontSize="20" MaxLength="4"
                         PreviewTextInput="OnPreviewTextInput"
                         GotFocus="OnTextBoxGotFocus"/>
                <TextBlock Grid.Column="3" Grid.Row="2" Text=":" Foreground="#55FFFFFF"
                           FontSize="20" FontWeight="Light" VerticalAlignment="Center" Margin="6,0"/>
                <TextBox x:Name="SecondsBox" Grid.Column="4" Grid.Row="2"
                         HorizontalAlignment="Stretch" TextAlignment="Center"
                         FontSize="20" MaxLength="4"
                         PreviewTextInput="OnPreviewTextInput"
                         GotFocus="OnTextBoxGotFocus"/>
            </Grid>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="CancelButton" Content="Cancel" Width="84" Click="OnCancel"
                        Margin="0,0,8,0"/>
                <Button x:Name="SetButton" Content="Set Time" Width="84" Click="OnSet"
                        Style="{StaticResource AccentButton}"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</views:GlassWindowBase>
