<views:GlassWindowBase x:Class="Flux.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:Flux.Views"
        Title="Settings"
        Width="520" Height="340"
        MouseLeftButtonDown="OnMouseLeftButtonDown">
    <Grid>
        <!-- Gradient overlay -->
        <Border CornerRadius="16">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#18FFFFFF" Offset="0"/>
                    <GradientStop Color="#08FFFFFF" Offset="0.5"/>
                    <GradientStop Color="#00FFFFFF" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
        </Border>

        <!-- Content -->
        <Grid Margin="20">
            <DockPanel>
                <TabControl x:Name="TabControl" SelectionChanged="OnTabChanged">
                <!-- Appearance Tab -->
                <TabItem Header="Appearance" x:Name="AppearanceTab">
                    <StackPanel Margin="0,4,0,0">
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Font" Foreground="#AAFFFFFF" VerticalAlignment="Center" FontSize="13"/>
                            <ComboBox x:Name="FontCombo" Grid.Column="1"
                                      SelectionChanged="OnFontChanged"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Size" Foreground="#AAFFFFFF" VerticalAlignment="Center" FontSize="13"/>
                            <Slider x:Name="SizeSlider" Grid.Column="1"
                                    Minimum="12" Maximum="120" IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="OnSizeChanged" VerticalAlignment="Center"/>
                            <TextBlock x:Name="SizeLabel" Grid.Column="2"
                                       Foreground="#CCFFFFFF" VerticalAlignment="Center"
                                       HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Color" Foreground="#AAFFFFFF" VerticalAlignment="Center" FontSize="13"/>
                            <Button x:Name="ColorButton" Grid.Column="1"
                                    Width="36" Height="24"
                                    Click="OnColorClick" Padding="0"
                                    BorderBrush="#28FFFFFF">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                CornerRadius="6"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="1.5"
                                                Width="{TemplateBinding Width}" Height="{TemplateBinding Height}"/>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="BorderBrush" Value="#55FFFFFF"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>
                        <Grid Margin="0,0,0,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="90"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="36"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Opacity" Foreground="#AAFFFFFF" VerticalAlignment="Center" FontSize="13"/>
                            <Slider x:Name="OpacitySlider" Grid.Column="1"
                                    Minimum="0" Maximum="100" IsSnapToTickEnabled="True" TickFrequency="1"
                                    ValueChanged="OnOpacityChanged" VerticalAlignment="Center"/>
                            <TextBlock x:Name="OpacityLabel" Grid.Column="2"
                                       Foreground="#CCFFFFFF" VerticalAlignment="Center"
                                       HorizontalAlignment="Right" FontSize="12"/>
                        </Grid>
                        <Button Content="Reset to Defaults" HorizontalAlignment="Left"
                                Click="OnResetAppearance" Margin="0,6,0,0"/>
                    </StackPanel>
                </TabItem>

                <!-- Shortcuts Tab -->
                <TabItem Header="Shortcuts" x:Name="ShortcutsTab">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                        <StackPanel x:Name="ShortcutsPanel">
                            <!-- Populated in code-behind -->
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- General Tab -->
                <TabItem Header="General" x:Name="GeneralTab">
                    <StackPanel Margin="0,8,0,0">
                        <CheckBox x:Name="LaunchAtLoginCheck" Content="Launch at login"
                                  Margin="0,0,0,12"
                                  Checked="OnLaunchAtLoginChanged" Unchecked="OnLaunchAtLoginChanged"/>
                        <CheckBox x:Name="ShowInFullScreenCheck" Content="Show in full screen"
                                  Margin="0,0,0,12"
                                  Checked="OnShowInFullScreenChanged" Unchecked="OnShowInFullScreenChanged"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
            </DockPanel>
            <!-- Close button overlaid at top-right, vertically aligned with tab pills -->
            <Button Style="{StaticResource CloseButton}" Click="OnClose"
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,3,0,0"/>
        </Grid>
    </Grid>
</views:GlassWindowBase>
